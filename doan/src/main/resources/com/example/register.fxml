<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx" 
      xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.example.controller.RegisterController"
      style="-fx-background-color: #f5f5f5;">
    
    <padding>
        <Insets top="30" right="50" bottom="30" left="50"/>
    </padding>

    <!-- Tiêu đề -->
    <Label text="ĐĂNG KÝ TÀI KHOẢN" style="-fx-text-fill: #2196F3; -fx-font-weight: bold;">
        <font>
            <Font size="24"/>
        </font>
    </Label>

    <Region prefHeight="10"/>

    <!-- Form đăng ký -->
    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25;">
        <effect>
            <javafx.scene.effect.DropShadow color="#00000033" radius="10"/>
        </effect>

        <!-- Tên đăng nhập -->
        <VBox spacing="5">
            <Label text="Tên đăng nhập *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtTenDangNhap" promptText="Nhập tên đăng nhập" 
                      style="-fx-padding: 8; -fx-border-color: #ddd; -fx-border-radius: 5;"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="5">
            <Label text="Email *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtEmail" promptText="Nhập email" 
                      style="-fx-padding: 8; -fx-border-color: #ddd; -fx-border-radius: 5;"/>
        </VBox>

        <!-- Họ tên -->
        <VBox spacing="5">
            <Label text="Họ và tên *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtHoTen" promptText="Nhập họ và tên" 
                      style="-fx-padding: 8; -fx-border-color: #ddd; -fx-border-radius: 5;"/>
        </VBox>

        <!-- Mật khẩu -->
        <VBox spacing="5">
            <Label text="Mật khẩu *" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="txtMatKhau" promptText="Nhập mật khẩu (tối thiểu 6 ký tự)" 
                          style="-fx-padding: 8; -fx-border-color: #ddd; -fx-border-radius: 5;"/>
        </VBox>

        <!-- Xác nhận mật khẩu -->
        <VBox spacing="5">
            <Label text="Xác nhận mật khẩu *" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="txtXacNhanMatKhau" promptText="Nhập lại mật khẩu" 
                          style="-fx-padding: 8; -fx-border-color: #ddd; -fx-border-radius: 5;"/>
        </VBox>

        <!-- Thông báo -->
        <Label fx:id="lblThongBao" text="" wrapText="true" style="-fx-font-size: 12px;"/>

        <!-- Nút đăng ký -->
        <Button fx:id="btnDangKy" text="Đăng ký" onAction="#handleDangKy" 
                maxWidth="Infinity" 
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;">
            <font>
                <Font name="System Bold" size="14"/>
            </font>
        </Button>

        <!-- Link quay lại -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Đã có tài khoản?" style="-fx-text-fill: #666;"/>
            <Hyperlink fx:id="linkDangNhap" text="Đăng nhập" onAction="#handleQuayLai" 
                      style="-fx-text-fill: #2196F3;"/>
        </HBox>
    </VBox>

</VBox>
