<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.controller.DashboardController"
            style="-fx-background-color: #f5f5f5;">

    <!-- HEADER -->
    <top>
        <VBox style="-fx-background-color: #2196F3; -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="🏦 HỆ THỐNG QUẢN LÝ CHI TIÊU" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblSoTaiKhoan" text="STK: " style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label fx:id="lblXinChao" text="Xin chào" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Button fx:id="btnDangXuat" text="Đăng xuất" onAction="#handleDangXuat"
                        style="-fx-background-color: white; -fx-text-fill: #2196F3; -fx-cursor: hand; -fx-padding: 8 15;"/>
            </HBox>
        </VBox>
    </top>

    <!-- LEFT SIDEBAR - MENU -->
    <left>
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-min-width: 200;">
            <Label text="MENU" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #666;"/>
            <Separator/>
            
            <Button text="🏠 Trang chủ" maxWidth="Infinity" onAction="#handleRefresh"
                    style="-fx-background-color: #E3F2FD; -fx-text-fill: #2196F3; -fx-alignment: CENTER-LEFT; -fx-padding: 10; -fx-cursor: hand; -fx-font-weight: bold;"/>
            
            <Button fx:id="btnGiaoDich" text="💸 Giao dịch" maxWidth="Infinity" onAction="#handleGiaoDich"
                    style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-alignment: CENTER-LEFT; -fx-padding: 10; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- CENTER - CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            
            <!-- Card Số dư -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
                <effect><javafx.scene.effect.DropShadow color="#00000022" radius="8"/></effect>
                <Label text="💰 SỐ DƯ TÀI KHOẢN" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                <Label fx:id="lblSoDu" text="0 đ" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: green;"/>
                <Label text="Số dư hiện tại" style="-fx-font-size: 11px; -fx-text-fill: #999;"/>
            </VBox>
                
            <!-- Bảng giao dịch -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                <effect><javafx.scene.effect.DropShadow color="#00000022" radius="8"/></effect>
                
                <HBox alignment="CENTER_LEFT">
                    <Label text="📋 LỊCH SỬ GIAO DỊCH" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🔄 Làm mới" onAction="#handleRefresh" 
                            style="-fx-background-color: #E3F2FD; -fx-text-fill: #2196F3; -fx-cursor: hand; -fx-padding: 5 15;"/>
                </HBox>
                
                <TableView fx:id="tableGiaoDich" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNgay" text="Ngày giờ" prefWidth="140"/>
                        <TableColumn fx:id="colLoai" text="Loại" prefWidth="80"/>
                        <TableColumn fx:id="colTaiKhoan" text="Tài khoản" prefWidth="200"/>
                        <TableColumn fx:id="colSoTien" text="Số tiền" prefWidth="150"/>
                        <TableColumn fx:id="colNoiDung" text="Nội dung" prefWidth="300"/>
                    </columns>
                    <placeholder>
                        <Label text="Chưa có giao dịch nào" style="-fx-text-fill: #999;"/>
                    </placeholder>
                </TableView>
            </VBox>
            
        </VBox>
    </center>

</BorderPane>